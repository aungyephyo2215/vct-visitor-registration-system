# Database
DATABASE_URL="postgresql://vrs_user:vrs_password@localhost:5432/vrs_db"

# Optional overrides for docker-compose.yml
DB_USER=vrs_user
DB_PASSWORD=vrs_password
DB_NAME=vrs_db
DB_PORT=5432

# Authentication
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
BCRYPT_ROUNDS=12
QR_EXPIRES_MINUTES=1440
