# Database
DATABASE_URL="postgresql://vrs_user:vrs_password@localhost:5432/vrs_db"

# Optional overrides for docker-compose.yml
DB_USER=vrs_user
DB_PASSWORD=vrs_password
DB_NAME=vrs_db
DB_PORT=5432

# Authentication
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000
NODE_ENV=development
BCRYPT_ROUNDS=12
QR_EXPIRES_MINUTES=1440

# Email Delivery
EMAIL_PROVIDER=noop
EMAIL_FROM="Visitor Registration System <no-reply@example.com>"
EMAIL_REPLY_TO=
EMAIL_MOCK_FAIL=false
QR_EMAIL_ENABLED=true
QR_EMAIL_TIMEOUT_MS=10000

# SMTP Provider
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_REQUIRE_TLS=false
