// Prisma schema for Visitor Registration System
// Generated from database/schema.md

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──────────────────────────────────────────

enum PropertyType {
  CONDO
  APARTMENT
  OFFICE
  WAREHOUSE
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
}

enum UnitStatus {
  OCCUPIED
  VACANT
  MAINTENANCE
}

enum UserRole {
  SUPER_ADMIN
  PROPERTY_ADMIN
  SECURITY_GUARD
  RESIDENT
  OFFICE_STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum IdType {
  NRC
  PASSPORT
  DRIVING_LICENSE
  COMPANY_ID
  OTHER
}

enum VisitPurpose {
  FAMILY_VISIT
  BUSINESS_MEETING
  DELIVERY
  MAINTENANCE
  INTERVIEW
  CONTRACTOR
  OTHER
}

enum VisitStatus {
  EXPECTED
  CHECKED_IN
  CHECKED_OUT
  NO_SHOW
  CANCELLED
}

enum QRStatus {
  ACTIVE
  USED
  EXPIRED
  REVOKED
}

enum AuditAction {
  LOGIN
  LOGOUT
  CREATE_VISITOR
  UPDATE_VISITOR
  DELETE_VISITOR
  CREATE_VISIT
  UPDATE_VISIT
  GENERATE_QR
  CHECK_IN
  CHECK_OUT
  FAILED_QR_SCAN
  MANUAL_CHECKOUT
  BLOCKLIST_MATCH
  CREATE_INVITATION
  UPDATE_INVITATION
  DELETE_INVITATION
  APPROVE_INVITATION
  REJECT_INVITATION
  VERIFY_VISITOR
  ATTACH_VISITOR
}

enum InvitationStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

enum VisitorType {
  GUEST
  FAMILY
  VIP
  VENDOR
  CONTRACTOR
  DELIVERY
  AUDITOR
  GOVERNMENT
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum BlocklistStatus {
  ACTIVE
  REMOVED
}

enum NotificationType {
  INVITATION_CREATED
  INVITATION_APPROVED
  INVITATION_REJECTED
  QR_GENERATED
  VISITOR_VERIFIED
  CHECKED_IN
  CHECKED_OUT
}

enum NotificationResourceType {
  invitation
  visit
  verification
}

// ── Models ──────────────────────────────────────────

model Property {
  id         String         @id @default(uuid())
  name       String
  type       PropertyType
  address    String
  timezone   String
  status     PropertyStatus
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt
  deleted_at DateTime?

  units      Unit[]
  users      User[]
  visitors   Visitor[]
  visits     Visit[]
  qrCodes    QRCode[]
  auditLogs  AuditLog[]
  blocklists Blocklist[]
  invitations Invitation[]
  badges     Badge[]
  verifications Verification[]
  notifications Notification[]

  @@index([status])
  @@map("properties")
}

model Unit {
  id          String       @id @default(uuid())
  property_id String
  unit_no     String
  floor       Int
  status      UnitStatus
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  deleted_at  DateTime?

  property Property @relation(fields: [property_id], references: [id])
  users    User[]
  visits   Visit[]
  invitations Invitation[]

  @@unique([property_id, unit_no])
  @@index([property_id])
  @@index([property_id, status])
  @@map("units")
}

model User {
  id            String     @id @default(uuid())
  property_id   String?
  unit_id       String?
  name          String
  email         String     @unique
  password_hash String
  role          UserRole
  status        UserStatus
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  deleted_at    DateTime?

  property    Property?   @relation(fields: [property_id], references: [id])
  unit        Unit?       @relation(fields: [unit_id], references: [id])
  visits      Visit[]     @relation("hostedVisits")
  auditLogs   AuditLog[]
  blocklists  Blocklist[]
  invitations           Invitation[] @relation("invitedBy")
  approvedInvitations   Invitation[] @relation("approvedBy")
  approvals             Approval[]
  verifications         Verification[]
  notifications         Notification[]

  @@index([property_id])
  @@index([unit_id])
  @@index([role])
  @@index([status])
  @@index([property_id, role])
  @@index([property_id, status])
  @@map("users")
}

model Visitor {
  id          String   @id @default(uuid())
  property_id String
  name        String
  phone       String
  id_type     IdType
  id_number   String
  photo_url   String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  deleted_at  DateTime?

  property Property @relation(fields: [property_id], references: [id])
  visits   Visit[]
  verifications Verification[]

  @@index([property_id])
  @@index([phone])
  @@index([id_number])
  @@index([property_id, phone])
  @@index([property_id, id_number])
  @@map("visitors")
}

model Visit {
  id                  String       @id @default(uuid())
  property_id         String
  visitor_id          String?
  unit_id             String
  host_user_id        String?
  purpose             VisitPurpose
  notes               String?
  vehicle_number      String?
  expected_checkin_time DateTime?
  checkin_time        DateTime?
  checkout_time       DateTime?
  status              VisitStatus
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt
  deleted_at          DateTime?

  property Property @relation(fields: [property_id], references: [id])
  visitor  Visitor?  @relation(fields: [visitor_id], references: [id])
  unit     Unit     @relation(fields: [unit_id], references: [id])
  host     User?    @relation("hostedVisits", fields: [host_user_id], references: [id])
  qrCodes  QRCode[]  @relation("VisitQRCodes")
  invitations Invitation[]  @relation("VisitInvitations")
  verification Verification?

  @@index([property_id])
  @@index([visitor_id])
  @@index([unit_id])
  @@index([host_user_id])
  @@index([status])
  @@index([expected_checkin_time])
  @@index([checkin_time])
  @@index([property_id, status, expected_checkin_time])
  @@index([property_id, checkin_time])
  @@index([property_id, visitor_id])
  @@index([property_id, unit_id])
  @@map("visits")
}

model QRCode {
  id          String    @id @default(uuid())
  property_id String
  visit_id    String
  token_hash  String    @unique
  status      QRStatus
  expires_at  DateTime
  used_at     DateTime?
  revoked_at  DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  property Property @relation(fields: [property_id], references: [id])
  visit    Visit    @relation("VisitQRCodes", fields: [visit_id], references: [id])

  @@index([property_id])
  @@index([visit_id])
  @@index([status])
  @@index([expires_at])
  @@index([property_id, status, expires_at])
  @@map("qr_codes")
}

model AuditLog {
  id            String       @id @default(uuid())
  property_id   String
  user_id       String?
  action        AuditAction
  resource_type String
  resource_id   String?
  ip_address    String
  user_agent    String
  metadata      Json?
  created_at    DateTime     @default(now())

  property Property @relation(fields: [property_id], references: [id])
  user     User?    @relation(fields: [user_id], references: [id])

  @@index([property_id])
  @@index([user_id])
  @@index([action])
  @@index([created_at])
  @@index([property_id, created_at])
  @@index([property_id, action])
  @@index([property_id, user_id])
  @@map("audit_logs")
}

model Blocklist {
  id           String          @id @default(uuid())
  property_id  String
  visitor_name String
  phone        String?
  id_number    String?
  reason       String
  status       BlocklistStatus
  created_by   String
  created_at   DateTime        @default(now())
  updated_at   DateTime        @updatedAt
  deleted_at   DateTime?

  property Property @relation(fields: [property_id], references: [id])
  creator  User     @relation(fields: [created_by], references: [id])

  @@index([property_id])
  @@index([phone])
  @@index([id_number])
  @@index([status])
  @@index([property_id, phone])
  @@index([property_id, id_number])
  @@index([property_id, status])
  @@map("blocklists")
}

model Notification {
  id            String                   @id @default(uuid())
  user_id       String
  property_id   String
  type          NotificationType
  title         String
  message       String
  resource_type NotificationResourceType
  resource_id   String?
  action_url    String?
  metadata      Json?
  is_read       Boolean                  @default(false)
  read_at       DateTime?
  created_at    DateTime                 @default(now())
  updated_at    DateTime                 @updatedAt

  user     User     @relation(fields: [user_id], references: [id])
  property Property @relation(fields: [property_id], references: [id])

  @@index([user_id, is_read, created_at])
  @@index([property_id])
  @@index([user_id, created_at])
  @@map("notifications")
}

model Invitation {
  id               String           @id @default(uuid())
  property_id      String
  invited_by       String
  visitor_name     String
  visitor_phone    String
  visitor_email    String?
  visitor_id_type  IdType?
  visitor_id_number String?
  visitor_type     VisitorType
  unit_id          String
  expected_date    DateTime
  expected_time    String?
  notes            String?
  status           InvitationStatus
  reason           String?
  approved_by      String?
  approved_at      DateTime?
  visit_id         String?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  deleted_at       DateTime?

  property Property @relation(fields: [property_id], references: [id])
  inviter  User     @relation("invitedBy", fields: [invited_by], references: [id])
  approver User?    @relation("approvedBy", fields: [approved_by], references: [id])
  unit     Unit     @relation(fields: [unit_id], references: [id])
  visit    Visit?    @relation("VisitInvitations", fields: [visit_id], references: [id])
  approvals Approval[]
  badges   Badge[]

  @@index([property_id])
  @@index([status])
  @@index([invited_by])
  @@index([property_id, status])
  @@index([property_id, expected_date])
  @@index([property_id, invited_by])
  @@index([visit_id])
  @@map("invitations")
}

model Approval {
  id             String         @id @default(uuid())
  invitation_id  String
  status         ApprovalStatus
  approved_by    String
  note           String?
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt

  invitation Invitation @relation(fields: [invitation_id], references: [id])
  approver   User       @relation(fields: [approved_by], references: [id])

  @@index([invitation_id])
  @@index([invitation_id, status])
  @@map("approvals")
}

model Badge {
  id            String   @id @default(uuid())
  property_id   String
  invitation_id String?
  visit_id      String?
  visitor_id    String?
  badge_type    String
  badge_data    Json?
  generated_at  DateTime @default(now())
  printed_at    DateTime?
  expires_at    DateTime?

  property   Property   @relation(fields: [property_id], references: [id])
  invitation Invitation? @relation(fields: [invitation_id], references: [id])

  @@index([property_id])
  @@index([invitation_id])
  @@index([visit_id])
  @@map("badges")
}

model Verification {
  id                String   @id @default(uuid())
  property_id       String
  visit_id          String
  visitor_id        String?
  photo_url         String?
  vehicle_number    String?
  nda_signed        Boolean  @default(false)
  safety_form_signed Boolean @default(false)
  verified_by       String
  verified_at       DateTime @default(now())
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  property Property @relation(fields: [property_id], references: [id])
  visit    Visit    @relation(fields: [visit_id], references: [id])
  visitor  Visitor? @relation(fields: [visitor_id], references: [id])
  verifier User     @relation(fields: [verified_by], references: [id])

  @@unique([visit_id])
  @@index([property_id])
  @@index([verified_by])
  @@map("verifications")
}
